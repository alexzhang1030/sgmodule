#!name=VPN Split DNS Router
#!desc=Resolve one internal DNS suffix through a VPN DNS server and route private VPN addresses directly. After disabling this module, run Flush DNS to clear cached overrides.
#!author=pi
#!category=Network
#!system=mac
#!arguments=suffix:corp,dns-server:10.0.0.53
#!arguments-desc=suffix: Bare internal DNS suffix. Examples: corp, corp.example.com, internal.example.com. dns-server: DNS server reachable through the VPN. Examples: 10.0.0.53, 100.100.100.100.

[Host]
{{{suffix}}} = server:{{{dns-server}}}
*.{{{suffix}}} = server:{{{dns-server}}}

[Rule]
DOMAIN-SUFFIX,{{{suffix}}},DIRECT
IP-CIDR,10.0.0.0/8,DIRECT,no-resolve
IP-CIDR,172.16.0.0/12,DIRECT,no-resolve
IP-CIDR,192.168.0.0/16,DIRECT,no-resolve
IP-CIDR,100.64.0.0/10,DIRECT,no-resolve
IP-CIDR6,fc00::/7,DIRECT,no-resolve
